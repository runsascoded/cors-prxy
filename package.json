{
  "name": "cors-prxy",
  "version": "0.1.0",
  "description": "Minimal, security-focused Lambda CORS proxy \u2014 deploy per-project allowlisted trampolines via CLI or GitHub Actions",
  "type": "module",
  "bin": {
    "cors-prxy": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/bundle-lambda.js && node scripts/bundle-cloudflare.js",
    "bundle": "node scripts/bundle-lambda.js && node scripts/bundle-cloudflare.js",
    "clean": "rm -rf node_modules/.vite dist",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "commander": "^13.0.0",
    "esbuild": "^0.24.0",
    "picomatch": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
